{
  "name": "@aituber-onair/comment-intelligence",
  "version": "0.0.0",
  "description": "Comment analysis and prioritization toolkit for AI VTubers and AI character streams.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "example:minimal": "vite --host 127.0.0.1 examples/minimal",
    "example:minimal:build": "vite build examples/minimal --outDir ../../dist/examples/minimal --emptyOutDir=false",
    "typecheck": "tsc --noEmit --project tsconfig.dev.json",
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest",
    "fmt": "biome format . --write",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aituber",
    "live-chat",
    "comment-analysis",
    "moderation",
    "vtuber",
    "browser"
  ],
  "author": "shinshin86 (https://github.com/shinshin86)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinshin86/aituber-onair.git",
    "directory": "packages/comment-intelligence"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^18.15.0",
    "@vitest/coverage-v8": "^1.3.1",
    "jsdom": "^22.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "vitest": "^1.3.1"
  },
  "browserslist": ["defaults", "not IE 11"],
  "publishConfig": {
    "access": "public"
  }
}
