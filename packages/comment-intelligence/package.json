{
  "name": "@aituber-onair/comment-intelligence",
  "version": "0.0.4",
  "description": "Comment analysis and prioritization toolkit for AI VTubers and AI character streams.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc --project tsconfig.json",
    "example:agent-decision-sample": "npm run build && node examples/agent-decision-sample/index.mjs",
    "example:live-comment-filter-sample": "vite --host 127.0.0.1 examples/live-comment-filter-sample",
    "example:live-comment-filter-sample:build": "vite build examples/live-comment-filter-sample",
    "typecheck": "tsc --noEmit --project tsconfig.dev.json",
    "test": "npm run typecheck && vitest run && npm run build && node test/dist-smoke.mjs",
    "test:watch": "vitest",
    "fmt": "biome format . --write",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aituber",
    "live-chat",
    "comment-analysis",
    "moderation",
    "vtuber",
    "browser"
  ],
  "author": "shinshin86 (https://github.com/shinshin86)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinshin86/aituber-onair.git",
    "directory": "packages/comment-intelligence"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^18.15.0",
    "@vitest/coverage-v8": "^3.2.6",
    "jsdom": "^22.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "vitest": "^3.2.6"
  },
  "browserslist": ["defaults", "not IE 11"],
  "publishConfig": {
    "access": "public"
  }
}
