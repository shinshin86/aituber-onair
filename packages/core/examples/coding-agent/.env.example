# Required: workspace sandbox root
# Can be overridden by CLI arg: node dist/index.js <workdir>
AGENT_WORKDIR=.

# Optional. This example supports only openai.
AGENT_PROVIDER=openai

# Optional OpenAI model id.
AGENT_MODEL=gpt-4.1

# veryShort | short | medium | long | veryLong | deep
AGENT_RESPONSE_LENGTH=medium

# Required API key
AGENT_API_KEY=

# Optional endpoint override (used in deterministic e2e mock as well)
AGENT_OPENAI_ENDPOINT=

# chat | responses | auto
# If omitted and AGENT_MODEL starts with gpt-5, this agent defaults to responses.
AGENT_OPENAI_GPT5_ENDPOINT_PREFERENCE=

# Loop / timeout controls
AGENT_MAX_HOPS=10
AGENT_ASSISTANT_TIMEOUT_MS=120000
AGENT_MAX_IDENTICAL_TOOL_CALLS=2
AGENT_MAX_CONSECUTIVE_TOOL_FAILURES=3

# History compaction
AGENT_HISTORY_MAX_MESSAGES=24
AGENT_HISTORY_KEEP_RECENT=8
AGENT_HISTORY_MAX_SUMMARY=1200

# Recoverable parse-error retry controls
AGENT_RECOVERABLE_RETRIES=2
AGENT_RECOVERY_RETRY_BACKOFF_MS=200
