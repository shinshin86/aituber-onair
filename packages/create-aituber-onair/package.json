{
  "name": "create-aituber-onair",
  "version": "0.2.3",
  "description": "Create an AITuber OnAir app from an official starter template",
  "type": "module",
  "bin": {
    "create-aituber-onair": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "templates",
    "template-manifest.json",
    "README.ja.md"
  ],
  "scripts": {
    "clean:templates": "node scripts/generate-templates.mjs --clean",
    "generate:templates": "node scripts/generate-templates.mjs",
    "verify:templates": "node scripts/verify-templates.mjs",
    "verify:registry": "node scripts/verify-registry-dependencies.mjs",
    "verify:registry:strict": "node scripts/verify-registry-dependencies.mjs --strict",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run generate:templates && npm run verify:templates",
    "test": "npm run build && node --test tests/*.test.mjs",
    "fmt": "biome format . --write",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "prepack": "npm run build && npm run generate:templates && npm run verify:templates",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aituber",
    "vtuber",
    "ai",
    "create",
    "cli",
    "template"
  ],
  "author": "shinshin86 (https://github.com/shinshin86)",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^18.15.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
