{
  "name": "@aituber-onair/noise",
  "version": "0.0.3",
  "description": "A context-aware response noise engine for AI VTubers.",
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/esm/web.d.ts",
        "default": "./dist/esm/web.js"
      },
      "require": {
        "types": "./dist/cjs/web.d.ts",
        "default": "./dist/cjs/web.js"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/esm/node.d.ts",
        "default": "./dist/esm/node.js"
      },
      "require": {
        "types": "./dist/cjs/node.d.ts",
        "default": "./dist/cjs/node.js"
      }
    }
  },
  "files": ["dist", "README.md", "README.ja.md"],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json && node -e \"require('node:fs').writeFileSync('dist/cjs/package.json', JSON.stringify({ type: 'commonjs' }))\"",
    "example:noise-sample": "vite --host 127.0.0.1 examples/noise-sample",
    "example:noise-sample:build": "vite build examples/noise-sample",
    "example:noise-session-sample": "vite --host 127.0.0.1 examples/noise-session-sample",
    "example:noise-session-sample:build": "vite build examples/noise-session-sample",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "npm run typecheck && vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "fmt": "biome format . --write",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "aituber",
    "vtuber",
    "llm",
    "response-rewrite",
    "noise",
    "browser"
  ],
  "author": "shinshin86 (https://github.com/shinshin86)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinshin86/aituber-onair.git",
    "directory": "packages/noise"
  },
  "dependencies": {
    "@aituber-onair/chat": "^0.48.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^18.15.0",
    "@vitest/coverage-v8": "^1.3.1",
    "jsdom": "^22.1.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "vitest": "^1.3.1"
  },
  "browserslist": ["defaults", "not IE 11"],
  "publishConfig": {
    "access": "public"
  }
}
